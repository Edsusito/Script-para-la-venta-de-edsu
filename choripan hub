-- [[ ⌨️ INPUT SYSTEM UNIFICADO ]]
UIS.InputBegan:Connect(function(input, gp)
    if gp then return end
    
    -- Animaciones Fast Attack (M1 Speed Up)
    if input.UserInputType == Enum.UserInputType.MouseButton1 and FastAttackAnimEnabled then
        local Character = LP.Character
        if Character and Character:FindFirstChild("Humanoid") then
            local Tool = Character:FindFirstChildOfClass("Tool")
            if Tool then
                for _, v in pairs(Character.Humanoid:GetPlayingAnimationTracks()) do
                    if v.Name:lower():find("attack") or v.Name:lower():find("slash") then
                        v:AdjustSpeed(2.5)
                    end
                end
            end
        end
    end

    -- Tecla H: OneShot Toggle 
    if input.KeyCode == Enum.KeyCode.H then
        local newState = not onenabledshotho
        toggleOneShot(newState)
        InstakillToggle:Set(newState)
    end

    -- Tecla G: Edsusito Manual Trigger
    if input.KeyCode == Enum.KeyCode.G then
        task.spawn(RunHeadLockVoid)
    end
    
    -- Tecla M: Edsusito Panel Principal
    if input.KeyCode == Enum.KeyCode.M then
        MainEds.Visible = not MainEds.Visible
    end

    -- Tecla N: Player List Toggle
    if input.KeyCode == Enum.KeyCode.N then
        PL.Visible = not PL.Visible
    end
    
    -- Tecla U: Fast Attack Masivo
    if input.KeyCode == TOGGLE_KEY_FA then
        FastAttackEnabled = not FastAttackEnabled
        FastAttackToggle:Set(FastAttackEnabled)
        if FastAttackEnabled then StartFastAttack() else StopFastAttack() end
    end
    
    -- Tecla B: UpLoop (Salto seguro)
    if input.KeyCode == Enum.KeyCode.B then
        local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local flag = hrp:FindFirstChild("UpLoop")
            if flag then 
                flag:Destroy() 
            else
                flag = Instance.new("BoolValue", hrp); flag.Name = "UpLoop"
                task.spawn(function()
                    while flag.Parent do
                        hrp.CFrame = hrp.CFrame * CFrame.new(0, 273861, 0)
                        task.wait(0.01)
                    end
                end)
            end
        end
    end
end)

