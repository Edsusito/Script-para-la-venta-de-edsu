local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local localPlayer = Players.LocalPlayer
local character = localPlayer.Character or localPlayer.CharacterAdded:Wait()
local humanoidRootPart = character:WaitForChild("HumanoidRootPart")

localPlayer.CharacterAdded:Connect(function(newCharacter)
    character = newCharacter
    humanoidRootPart = newCharacter:WaitForChild("HumanoidRootPart")
end)

-- [VARIABLES REALES DE BLOX FRUITS - NETWORKING]
local netFolder = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Net")
local registerAttack = netFolder:WaitForChild("RE/RegisterAttack")
local registerHit = netFolder:WaitForChild("RE/RegisterHit")
local enemiesFolder = Workspace:FindFirstChild("Enemies") or Workspace

-- Variables de Estado
local autoCompleteActive = false
local autoV4Active = false
local currentIslandNumber = 1
local maxRaidDistance = 450 -- Filtro en studs para ignorar NPCs de otras raids alejadas

-- ==========================================
-- COMPATIBLE FAST ATTACK ENGINE (H = 20)
-- ==========================================
local function executeRealFastAttack(enemy, headObject)
    if not enemy or not headObject then return end
    
    local tool = character:FindFirstChildOfClass("Tool")
    if tool then
        tool:Activate()
    end
    
    pcall(function()
        local targetsTable = {{enemy, headObject}}
        registerAttack:FireServer(0)
        task.wait(0.01) 
        registerHit:FireServer(headObject, targetsTable)
    end)
end

-- Filtrar enemigos vivos para atacar ÚNICAMENTE los de tu propia Raid local
local function getMyRaidEnemiesList()
    local enemyList = {}
    if enemiesFolder and humanoidRootPart then
        for _, object in ipairs(enemiesFolder:GetChildren()) do
            if object:IsA("Model") and object ~= character then
                local humanoid = object:FindFirstChildOfClass("Humanoid")
                local head = object:FindFirstChild("Head")
                local root = object:FindFirstChild("HumanoidRootPart")
                
                if humanoid and humanoid.Health > 0 and head and root then
                    -- VALIDACIÓN CRÍTICA: Ignorar si el NPC pertenece a la raid de otra persona alejada
                    local distance = (humanoidRootPart.Position - root.Position).Magnitude
                    if distance <= maxRaidDistance then
                        table.insert(enemyList, object)
                    end
                end
            end
        end
    end
    return enemyList
end

-- Identificar y localizar la siguiente isla correspondiente a TU progreso de Raid
local function findNextRaidIsland(islandNumber)
    for _, object in ipairs(Workspace:GetDescendants()) do
        if object:IsA("BasePart") or object:IsA("Model") then
            local objName = string.lower(object.Name)
            -- Filtra nombres clave como "island 2", "island2", "isla 2", "raid island"
            if (string.find(objName, "island") or string.find(objName, "isla")) and string.find(objName, tostring(islandNumber)) then
                if object:IsA("Model") then
                    return object:FindFirstChildOfClass("BasePart") or object.PrimaryPart
                end
                return object
            end
        end
    end
    return nil
end

-- Bucle Principal de Combate e Islas
local function runCombatLoop()
    while autoCompleteActive do
        if not character or not character:FindFirstChild("HumanoidRootPart") then
            character = localPlayer.Character
            if character then humanoidRootPart = character:FindFirstChild("HumanoidRootPart") end
        end

        local enemies = getMyRaidEnemiesList()
        
        if #enemies > 0 then
            for _, enemy in ipairs(enemies) do
                if not autoCompleteActive then break end
                
                local enemyHumanoid = enemy:FindFirstChildOfClass("Humanoid")
                local enemyHead = enemy:FindFirstChild("Head")
                
                if enemyHumanoid and enemyHumanoid.Health > 0 and enemyHead then
                    local maxTime = 0.4    
                    local elapsedTime = 0
                    
                    while elapsedTime < maxTime and enemyHumanoid.Health > 0 and autoCompleteActive do
                        if humanoidRootPart and character:FindFirstChild("Humanoid") and character.Humanoid.Health > 0 then
                            -- Altura de seguridad (20 unidades) para evitar hitboxes enemigos
                            humanoidRootPart.CFrame = enemyHead.CFrame * CFrame.new(0, 20, 0)
                        end
                        
                        executeRealFastAttack(enemy, enemyHead)
                        
                        task.wait(0.01) 
                        elapsedTime = elapsedTime + 0.01
                    end
                end
            end
        else
            -- Si no quedan enemigos en tu zona, verificar si el juego anunció el desbloqueo de la siguiente fase
            local playerGui = localPlayer:FindFirstChild("PlayerGui")
            local mainGui = playerGui and playerGui:FindFirstChild("Main")
            local centerMsg = mainGui and mainGui:FindFirstChild("CenterMsg") -- Alerta nativa de Blox Fruits
            
            -- Detectar si aparece el texto de nueva isla o si la sala actual está vacía por completo
            if centerMsg and centerMsg.Visible and (string.find(string.lower(centerMsg.Text), "desbloque") or string.find(string.lower(centerMsg.Text), "island")) then
                currentIslandNumber = currentIslandNumber + 1
                local nextIslandPart = findNextRaidIsland(currentIslandNumber)
                
                if nextIslandPart and humanoidRootPart then
                    task.wait(1.0) -- Pausa de estabilidad antes del viaje de fase
                    humanoidRootPart.CFrame = nextIslandPart.CFrame * CFrame.new(0, 25, 0)
                    task.wait(2.0) -- Espera de sincronización de mapa
                end
            end
        end
        task.wait()
    end
end

-- ==========================================
-- CORRECCIÓN: AUTO V4 ENGINE VIA INVENTARIO ("DESPERTAR")
-- ==========================================
task.spawn(function()
    while task.wait(1.0) do
        if autoV4Active and character then
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            local playerGui = localPlayer:FindFirstChild("PlayerGui")
            local mainGui = playerGui and playerGui:FindFirstChild("Main")
            local awakeningBar = mainGui and mainGui:FindFirstChild("Awakening")
            
            -- Verificar si el medidor de furia de la interfaz está activo y visible al máximo
            if awakeningBar and awakeningBar.Visible and humanoid then
                -- Buscar la herramienta Despertar en la mochila (Backpack) o en la mano
                local v4Tool = localPlayer.Backpack:FindFirstChild("Despertar") or character:FindFirstChild("Despertar")
                
                if v4Tool then
                    local currentWeapon = character:FindFirstChildOfClass("Tool")
                    
                    -- Intercambio rápido seguro para activar la V4
                    humanoid:EquipTool(v4Tool)
                    task.wait(0.1)
                    v4Tool:Activate()
                    task.wait(0.2)
                    
                    -- Regresar al arma de ataque original si existía una
                    if currentWeapon and currentWeapon.Name ~= "Despertar" then
                        humanoid:EquipTool(currentWeapon)
                    end
                    task.wait(10) -- Evita loops de re-equipamiento continuo
                end
            end
        end
    end
end)

