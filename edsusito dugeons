local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local localPlayer = Players.LocalPlayer
local character = localPlayer.Character or localPlayer.CharacterAdded:Wait()
local humanoidRootPart = character:WaitForChild("HumanoidRootPart")

localPlayer.CharacterAdded:Connect(function(newCharacter)
    character = newCharacter
    humanoidRootPart = newCharacter:WaitForChild("HumanoidRootPart")
end)

-- [VARIABLES REALES DE BLOX FRUITS - NETWORKING]
local netFolder = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Net")
local registerAttack = netFolder:WaitForChild("RE/RegisterAttack")
local registerHit = netFolder:WaitForChild("RE/RegisterHit")
local enemiesFolder = Workspace:FindFirstChild("Enemies") or Workspace

-- Variables de Estado
local autoCompleteActive = false
local autoV4Active = false
local selectedWeaponType = "Estilo de Combate" -- Valor por defecto

-- ==========================================
-- MOTOR DE CONTROL DE ARMAS (EQUIP AUTO)
-- ==========================================
local function equipSelectedWeapon()
    if not character then return end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    
    -- Verificar si ya tenemos el arma correcta equipada
    local currentTool = character:FindFirstChildOfClass("Tool")
    if currentTool and currentTool.Name ~= "Despertar" then
        -- Si ya hay algo equipado y coincide con el tipo, no hacemos nada
        if selectedWeaponType == "Espada" and currentTool:FindFirstChild("Sword") then
            return
        elseif selectedWeaponType == "Estilo de Combate" and (currentTool:FindFirstChild("Combat") or currentTool.Name == "Combat" or currentTool.Name == "Dark Step" or currentTool.Name == "Electric" or currentTool.Name == "Water Kung Fu" or currentTool.Name == "Dragon Breath") then
            return
        end
    end

    -- Buscar en el inventario (Backpack) para equipar
    for _, tool in ipairs(localPlayer.Backpack:GetChildren()) do
        if tool:IsA("Tool") then
            if selectedWeaponType == "Espada" and tool:FindFirstChild("Sword") then
                humanoid:EquipTool(tool)
                break
            elseif selectedWeaponType == "Estilo de Combate" and (tool:FindFirstChild("Combat") or tool.Name == "Combat" or tool.Name == "Dark Step" or tool.Name == "Electric" or tool.Name == "Water Kung Fu" or tool.Name == "Dragon Breath") then
                humanoid:EquipTool(tool)
                break
            end
        end
    end
end

-- ==========================================
-- INTEGRATED FAST ATTACK ENGINE (H = 20)
-- ==========================================
local function executeRealFastAttack(enemy, headObject)
    if not enemy or not headObject then return end
    
    -- Forzar que el arma elegida esté en la mano antes de golpear
    equipSelectedWeapon()
    
    local tool = character:FindFirstChildOfClass("Tool")
    if tool then
        tool:Activate()
    end
    
    pcall(function()
        local targetsTable = {{enemy, headObject}}
        registerAttack:FireServer(0)
        task.wait(0.01) 
        registerHit:FireServer(headObject, targetsTable)
    end)
end

local function getAliveEnemiesList()
    local enemyList = {}
    if enemiesFolder then
        for _, object in ipairs(enemiesFolder:GetChildren()) do
            if object:IsA("Model") and object ~= character then
                local humanoid = object:FindFirstChildOfClass("Humanoid")
                local head = object:FindFirstChild("Head")
                if humanoid and humanoid.Health > 0 and head then
                    table.insert(enemyList, object)
                end
            end
        end
    end
    return enemyList
end

-- Bucle Principal de Combate
local function runCombatLoop()
    while autoCompleteActive do
        if not character or not character:FindFirstChild("HumanoidRootPart") then
            character = localPlayer.Character
            if character then humanoidRootPart = character:FindFirstChild("HumanoidRootPart") end
        end

        local enemies = getAliveEnemiesList()
        
        if #enemies > 0 then
            for _, enemy in ipairs(enemies) do
                if not autoCompleteActive then break end
                
                local enemyHumanoid = enemy:FindFirstChildOfClass("Humanoid")
                local enemyHead = enemy:FindFirstChild("Head")
                
                if enemyHumanoid and enemyHumanoid.Health > 0 and enemyHead then
                    local maxTime = 0.4    
                    local elapsedTime = 0
                    
                    while elapsedTime < maxTime and enemyHumanoid.Health > 0 and autoCompleteActive do
                        if humanoidRootPart and character:FindFirstChild("Humanoid") and character.Humanoid.Health > 0 then
                            -- Altura de seguridad de 20 unidades solicitada
                            humanoidRootPart.CFrame = enemyHead.CFrame * CFrame.new(0, 20, 0)
                        end
                        
                        executeRealFastAttack(enemy, enemyHead)
                        
                        task.wait(0.01) 
                        elapsedTime = elapsedTime + 0.01
                    end
                end
            end
        else
            -- Si no hay enemigos, mantenemos el arma equipada por estabilidad
            equipSelectedWeapon()
        end
        task.wait()
    end
end

-- ==========================================
-- DETECTOR Y ACTIVADOR DE V4 ("DESPERTAR")
-- ==========================================
task.spawn(function()
    while task.wait(1.0) do
        if autoV4Active and character then
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            local playerGui = localPlayer:FindFirstChild("PlayerGui")
            
            -- Verificar si la furia (Awakening) está al máximo en la UI real
            local mainGui = playerGui and playerGui:FindFirstChild("Main")
            local awakeningFrame = mainGui and mainGui:FindFirstChild("Awakening")
            
            -- Si el juego indica que se puede usar la V4
            if awakeningFrame and awakeningFrame.Visible and humanoid then
                -- 1. Buscar la herramienta "Despertar" en el inventario o cuerpo
                local v4Tool = localPlayer.Backpack:FindFirstChild("Despertar") or character:FindFirstChild("Despertar")
                
                if v4Tool then
                    -- Guardar el arma que tenías puesta para no perder el hilo del ataque
                    local previousTool = character:FindFirstChildOfClass("Tool")
                    
                    -- Equipar "Despertar" y activarla
                    humanoid:EquipTool(v4Tool)
                    task.wait(0.1)
                    v4Tool:Activate()
                    task.wait(0.2)
                    
                    -- Volver a equipar tu arma de combate principal
                    if previousTool then
                        humanoid:EquipTool(previousTool)
                    else
                        equipSelectedWeapon()
                    end
                    
                    task.wait(10) -- Cooldown largo de seguridad
                end
            end
        end
    end
end)

