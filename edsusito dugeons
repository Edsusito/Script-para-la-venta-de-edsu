DungeonTab:CreateSection("Control Principal")

DungeonTab:CreateToggle({
    Name = "Auto Completar",
    CurrentValue = false,
    Flag = "EdsuAutoDungeonFlag",
    Callback = function(Value)
        autoDungeonActive = Value
        if Value then
            coroutine.wrap(RotateTargets)()
        else
            currentTarget = nil
            lastTarget = nil
            spawnPosition = nil
            Rayfield:Notify({
                Title = "⚔️ Edsusito Dungeon ⚔️",
                Content = "Ciclo de rotación pausado con éxito.",
                Duration = 2,
                Image = 4483362458,
            })
        end
    end,
})
