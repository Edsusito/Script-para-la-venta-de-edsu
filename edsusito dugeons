CombatTab:CreateToggle({
   Name = "Auto Completar (Matar NPCs)",
   CurrentValue = false,
   Flag = "AutoCombatFlag",
   Callback = function(Value)
      autoCompleteActive = Value
      if Value then
          task.spawn(runCombatLoop)
      end
   end,
})

CombatTab:CreateToggle({
   Name = "Auto Activar V4 (Despertar)",
   CurrentValue = false,
   Flag = "AutoV4RealFlag",
   Callback = function(Value)
      autoV4Active = Value
   end,
})

