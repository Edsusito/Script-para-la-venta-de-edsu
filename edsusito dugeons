-- Selector dinámico exigido por el profesor
CombatTab:CreateDropdown({
   Name = "Seleccionar Arma de Combate",
   Options = {"Estilo de Combate", "Espada"},
   CurrentOption = "Estilo de Combate",
   MultipleOptions = false,
   Flag = "WeaponSelectFlag",
   Callback = function(Option)
      selectedWeaponType = Option[1] or Option
      if autoCompleteActive then
          equipSelectedWeapon()
      end
   end,
})

