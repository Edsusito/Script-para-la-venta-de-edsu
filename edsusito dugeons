-- ⚔️ Edsusito Fast Attack ⚔️
-- TP encima de cada NPC, golpear hasta matarlo, luego cambiar de objetivo

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local FastAttackEnabled = true -- Actívalo en true para pruebas
local FAST_ATTACK_RANGE = 100

-- Buscar NPCs vivos cercanos
local function GetTargets()
    local targets = {}
    for _, npc in pairs(workspace:GetChildren()) do
        local hum = npc:FindFirstChild("Humanoid")
        local head = npc:FindFirstChild("Head")
        if hum and head and hum.Health > 0 then
            local dist = (head.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
            if dist <= FAST_ATTACK_RANGE then
                table.insert(targets, {npc, head})
            end
        end
    end
    return targets
end

-- Atacar un NPC hasta que muera
local function AttackNPC(npc, head)
    while FastAttackEnabled and npc and head and npc:FindFirstChild("Humanoid") and npc.Humanoid.Health > 0 do
        -- TP encima del NPC
        LocalPlayer.Character.HumanoidRootPart.CFrame = head.CFrame + Vector3.new(0,6,0)
        -- Golpe
        pcall(function()
            ReplicatedStorage.RigControllerEvent:FireServer("attack", "m1")
            ReplicatedStorage.RigControllerEvent:FireServer("hit", head)
        end)
        task.wait(0.3) -- velocidad de ataque
    end
end

-- Bucle principal
task.spawn(function()
    while FastAttackEnabled do
        local targets = GetTargets()
        for _, target in pairs(targets) do
            local npc, head = target[1], target[2]
            AttackNPC(npc, head) -- lo mata antes de pasar al siguiente
        end
        task.wait(0.2)
    end
end)
