local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Edsusito Dungeon",
   LoadingTitle = "Cargando Sistema...",
   LoadingSubtitle = "by Edsu",
   ConfigurationSaving = {
      Enabled = false
   },
   Discord = {
      Enabled = false
   },
   KeySystem = false
})

local CombatTab = Window:CreateTab("Combate", 4483362458) -- Icono de espada

CombatTab:CreateSection("Automatización")

CombatTab:CreateToggle({
   Name = "Auto Completar (Matar NPCs)",
   CurrentValue = false,
   Flag = "AutoCombatFlag",
   Callback = function(Value)
      autoCompleteActive = Value
      if Value then
          task.spawn(runCombatLoop)
      end
   end,
})

CombatTab:CreateToggle({
   Name = "Auto Activar V4",
   CurrentValue = false,
   Flag = "AutoV4Flag",
   Callback = function(Value)
      autoV4Active = Value
   end,
})

Rayfield:Notify({
   Title = "Sistema Listo",
