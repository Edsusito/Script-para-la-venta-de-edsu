local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local localPlayer = Players.LocalPlayer
local character = localPlayer.Character or localPlayer.CharacterAdded:Wait()
local humanoidRootPart = character:WaitForChild("HumanoidRootPart")

local spawnPosition = nil -- Guarda el punto de aparición en la sala actual

-- Evento para cuando el personaje muere y revive
localPlayer.CharacterAdded:Connect(function(newCharacter)
    character = newCharacter
    humanoidRootPart = newCharacter:WaitForChild("HumanoidRootPart")
    -- Al revivir, registramos inmediatamente la nueva posición de spawn para no perder el hilo
    task.wait(0.5)
    if humanoidRootPart then
        spawnPosition = humanoidRootPart.Position
    end
end)

local netFolder = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Net")
local registerAttack = netFolder:WaitForChild("RE/RegisterAttack")
local registerHit = netFolder:WaitForChild("RE/RegisterHit")
local enemiesFolder = Workspace:FindFirstChild("Enemies") or Workspace

local autoDungeonActive = false
local currentTarget = nil
local lastTarget = nil -- Guarda el último objetivo para forzar la rotación

-- Función para equipar automáticamente la espada (Sword)
local function EquipSword()
    if not character then return end
    local currentTool = character:FindFirstChildOfClass("Tool")
    if currentTool and (currentTool.ToolTip == "Sword" or string.find(string.lower(currentTool.Name), "sword") or string.find(string.lower(currentTool.Name), "katana")) then
        return
    end
    
    local backpack = localPlayer:FindFirstChildOfClass("Backpack")
    if backpack then
        for _, tool in ipairs(backpack:GetChildren()) do
            if tool:IsA("Tool") and (tool.ToolTip == "Sword" or string.find(string.lower(tool.Name), "sword") or string.find(string.lower(tool.Name), "katana")) then
                local humanoid = character:FindFirstChildOfClass("Humanoid")
                if humanoid then
                    humanoid:EquipTool(tool)
                    break
                end
            end
        end
    end
end

local function GetClosestEnemy()
    local closestEnemy = nil
    local shortestDistance = math.huge
    local currentCharacter = localPlayer.Character
    
    if not currentCharacter or not currentCharacter:FindFirstChild("HumanoidRootPart") then 
        return nil 
    end
    
    local myPos = currentCharacter.HumanoidRootPart.Position
    local sourceFolder = Workspace:FindFirstChild("Enemies") or enemiesFolder
    
    if sourceFolder then
        local children = sourceFolder:GetChildren()
        local primaryCandidates = {}
        local backupCandidates = {}
        
        for i = 1, #children do
            local object = children[i]
            if object:IsA("Model") and object ~= currentCharacter then
                local humanoid = object:FindFirstChildOfClass("Humanoid")
                local root = object:FindFirstChild("HumanoidRootPart") or object:FindFirstChild("Head")
                
                if humanoid and humanoid.Health > 0 and root and object.Parent then
                    local distance = (root.Position - myPos).Magnitude
                    if object ~= lastTarget then
                        table.insert(primaryCandidates, {model = object, dist = distance})
                    else
                        table.insert(backupCandidates, {model = object, dist = distance})
                    end
                end
            end
        end
        
        local targetList = #primaryCandidates > 0 and primaryCandidates or backupCandidates
        
        for i = 1, #targetList do
            local candidate = targetList[i]
            if candidate.dist < shortestDistance then
                shortestDistance = candidate.dist
                closestEnemy = candidate.model
            end
        end
    end
    return closestEnemy
end

local function TeleportToEnemy(enemy)
    if not enemy or not enemy.Parent or not humanoidRootPart then return false end
    
    local enemyRoot = enemy:FindFirstChild("HumanoidRootPart") or enemy:FindFirstChild("Head")
    if not enemyRoot then return false end
    
    local success, err = pcall(function()
        humanoidRootPart.CFrame = enemyRoot.CFrame * CFrame.new(0, 20, 0)
    end)
    
    if not success then
        local raycastParams = RaycastParams.new()
        raycastParams.FilterDescendantsInstances = {character, enemy}
        raycastParams.FilterType = Enum.RaycastFilterType.Exclude
        
        local raycastResult = Workspace:Raycast(enemyRoot.Position, Vector3.new(0, -100, 0), raycastParams)
        if raycastResult then
            humanoidRootPart.CFrame = CFrame.new(raycastResult.Position + Vector3.new(0, 3, 0))
        end
        return false
    end
    return true
end

local function AttackEnemy(enemy)
    if not enemy or not enemy.Parent then return end
    
    local enemyHead = enemy:FindFirstChild("Head")
    local enemyHumanoid = enemy:FindFirstChildOfClass("Humanoid")
    if not enemyHead or not enemyHumanoid then return end
    
    EquipSword() -- Forzamos el uso de la espada antes de atacar
    local tool = character:FindFirstChildOfClass("Tool")
    if tool then tool:Activate() end
    
    pcall(function()
        local targetsTable = {{enemy, enemyHead}}
        registerAttack:FireServer(0)
        registerHit:FireServer(enemyHead, targetsTable)
    end)
end

-- Función para buscar el portal de SALIDA real y avanzar de sala automáticamente
local function AutoPassRoom()
    local mapFolder = Workspace:FindFirstChild("Map")
    if not mapFolder then return end
    local dungeonFolder = mapFolder:FindFirstChild("Dungeon")
    if not dungeonFolder then return end
    
    local rooms = dungeonFolder:GetChildren()
    local availablePortals = {}
    
    -- Recolectamos todos los portales activos en el mapa
    for i = 1, #rooms do
        local room = rooms[i]
        local teleporter = room:FindFirstChild("ExitTeleporter")
        if teleporter then
            local rootPart = teleporter:FindFirstChild("Root")
            if rootPart and rootPart:IsA("BasePart") then
                local touchTransmitter = rootPart:FindFirstChildOfClass("TouchTransmitter")
                if touchTransmitter then
                    table.insert(availablePortals, rootPart)
                end
            end
        end
    end
    
    -- Si solo hay un portal en el mapa, lo tomamos directo (sin importar distancia)
    if #availablePortals == 1 and humanoidRootPart then
        local targetPortal = availablePortals[1]
        humanoidRootPart.CFrame = targetPortal.CFrame
        task.wait(0.1)
        if firetouchinterest then
            firetouchinterest(humanoidRootPart, targetPortal, 0)
            task.wait(0.1)
            firetouchinterest(humanoidRootPart, targetPortal, 1)
        end
        spawnPosition = nil
        return true
    elseif #availablePortals > 1 and humanoidRootPart then
        -- Si hay más de uno, filtramos para ignorar el que esté cerca de nuestro spawn
        for _, rootPart in ipairs(availablePortals) do
            local isExitPortal = true
            if spawnPosition then
                local distanceToSpawn = (rootPart.Position - spawnPosition).Magnitude
                if distanceToSpawn < 50 then -- Entrada
                    isExitPortal = false
                end
            end
            
            if isExitPortal then
                humanoidRootPart.CFrame = rootPart.CFrame
                task.wait(0.1)
                if firetouchinterest then
                    firetouchinterest(humanoidRootPart, rootPart, 0)
                    task.wait(0.1)
                    firetouchinterest(humanoidRootPart, rootPart, 1)
                end
                spawnPosition = nil
                return true
            end
        end
    end
    return false
end

local function RotateTargets()
    -- Guardamos la posición inicial al activar el script
    if humanoidRootPart then
        spawnPosition = humanoidRootPart.Position
    end

    while autoDungeonActive do
        currentTarget = GetClosestEnemy()
        
        if currentTarget then
            -- Si empezamos a pelear, nos aseguramos de registrar nuestro spawn si no se había guardado
            if not spawnPosition and humanoidRootPart then
                spawnPosition = humanoidRootPart.Position
            end
            
            lastTarget = currentTarget
            local enemyHumanoid = currentTarget:FindFirstChildOfClass("Humanoid")
            local timer = 0
            
            while autoDungeonActive and currentTarget and currentTarget.Parent and enemyHumanoid and enemyHumanoid.Health > 0 and timer < 0.5 do
                TeleportToEnemy(currentTarget)
                AttackEnemy(currentTarget)
                
                task.wait(0.01)
                timer = timer + 0.01
            end
        else
            -- Si no hay enemigos, esperamos 1 segundo y buscamos el portal de salida
            task.wait(1.0)
            local passed = AutoPassRoom()
            if not passed then
                task.wait(0.2) -- Pausa corta para reevaluar si aún no aparece el portal de salida real
            end
        end
    end
end

