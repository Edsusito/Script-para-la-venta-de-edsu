local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local CoreGui = game:GetService("CoreGui")

local localPlayer = Players.LocalPlayer
local character = localPlayer.Character or localPlayer.CharacterAdded:Wait()
local humanoidRootPart = character:WaitForChild("HumanoidRootPart")

-- [BLOX FRUITS REAL VARIABLES]
local enemiesFolder = Workspace:FindFirstChild("Enemies") or Workspace
local rigController = ReplicatedStorage:FindFirstChild("RigControllerEvent")

local autoCompleteActive = false

-- ==========================================
-- CORE FUNCTIONS
-- ==========================================

-- Remote attack function using Blox Fruits event
local function attackEnemy()
    if rigController then
        rigController:FireServer("weaponChange")
    end
    
    -- Failsafe: Activate equipped tool (Combat/Sword/Fruit)
    local tool = character:FindFirstChildOfClass("Tool")
    if tool then
        tool:Activate()
    end
end

-- Scan the workspace folder for valid targets
local function getAliveEnemiesList()
    local enemyList = {}
    
    for _, object in ipairs(enemiesFolder:GetChildren()) do
        if object:IsA("Model") and object ~= character then
            local humanoid = object:FindFirstChildOfClass("Humanoid")
            local head = object:FindFirstChild("Head")
            
            if humanoid and humanoid.Health > 0 and head then
                table.insert(enemyList, object)
            end
        end
    end
    return enemyList
end

-- Dynamic search for the dungeon exit gate
local function findExitGate()
    local targetNames = {"Exit", "Gate", "Portal", "Barrier"}
    for _, object in ipairs(Workspace:GetDescendants()) do
        if object:IsA("BasePart") then
            for _, name in ipairs(targetNames) do
                if object.Name == name then
                    return object
                end
            end
        end
    end
    return nil
end

-- ==========================================
-- MAIN AUTOMATION LOOP
-- ==========================================
local function startAutoComplete()
    autoCompleteActive = true
    print("Auto Complete Sequence Started!")
    
    while autoCompleteActive do
        local enemies = getAliveEnemiesList()
        
        if #enemies == 0 then
            -- FAILSAFE: Wait 2.5 seconds to make sure the game loaded the new room's enemies
            print("Room looks empty. Checking for spawn delay...")
            task.wait(2.5) 
            enemies = getAliveEnemiesList() -- Double check the enemy list
            
            -- If it's still empty, then the room is officially cleared. Find the gate!
            if #enemies == 0 then
                print("Room cleared! Searching for exit gate...")
                local exitGate = findExitGate()
                
                if exitGate then
                    if character and character:FindFirstChild("Humanoid") and character.Humanoid.Health > 0 then
                        -- Teleport slightly in front of the gate object
                        humanoidRootPart.CFrame = exitGate.CFrame * CFrame.new(0, 0, -3)
                    end
                    task.wait(2) -- Wait time for the game to transition to the next room
                else
                    task.wait(1) 
                end
            end
        else
            -- 0.4 seconds target rotation loop (Strict requirements)
            for _, enemy in ipairs(enemies) do
                if not autoCompleteActive then break end
                
                local enemyHumanoid = enemy:FindFirstChildOfClass("Humanoid")
                local enemyHead = enemy:FindFirstChild("Head")
                
                if enemyHumanoid and enemyHumanoid.Health > 0 and enemyHead then
                    local maxTime = 0.4    
                    local hitInterval = 0.01 
                    local elapsedTime = 0
                    
                    while elapsedTime < maxTime and enemyHumanoid.Health > 0 and autoCompleteActive do
                        if character and character:FindFirstChild("Humanoid") and character.Humanoid.Health > 0 then
                            -- Position player right above enemy head
                            humanoidRootPart.CFrame = enemyHead.CFrame * CFrame.new(0, 4, 0)
                        end
                        
                        attackEnemy()
                        
                        task.wait(hitInterval)
                        elapsedTime = elapsedTime + hitInterval
                    end
                end
            end
        end
        task.wait(0.1)
    end
end

