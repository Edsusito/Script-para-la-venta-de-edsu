local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local localPlayer = Players.LocalPlayer
local character = localPlayer.Character or localPlayer.CharacterAdded:Wait()
local humanoidRootPart = character:WaitForChild("HumanoidRootPart")

localPlayer.CharacterAdded:Connect(function(newCharacter)
    character = newCharacter
    humanoidRootPart = newCharacter:WaitForChild("HumanoidRootPart")
end)

-- [VARIABLES REALES DE BLOX FRUITS - NETWORKING]
local netFolder = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Net")
local registerAttack = netFolder:WaitForChild("RE/RegisterAttack")
local registerHit = netFolder:WaitForChild("RE/RegisterHit")
local enemiesFolder = Workspace:FindFirstChild("Enemies") or Workspace

-- Variables de Estado Generales
local autoV4Active = false

-- Variables de Estado: MÓDULO DUNGEON
local autoDungeonActive = false

-- Variables de Estado: MÓDULO RAIDS
local autoRaidActive = false
local currentIslandNumber = 1
local maxRaidDistance = 500 
local travelingToNextIsland = false -- Evita loops de TP mientras viaja

-- ==========================================
-- COMPATIBLE FAST ATTACK ENGINE (H = 20)
-- ==========================================
local function executeRealFastAttack(enemy, headObject)
    if not enemy or not headObject then return end
    
    local tool = character:FindFirstChildOfClass("Tool")
    if tool then
        tool:Activate()
    end
    
    pcall(function()
        local targetsTable = {{enemy, headObject}}
        registerAttack:FireServer(0)
        task.wait(0.01) 
        registerHit:FireServer(headObject, targetsTable)
    end)
end

-- ==========================================
-- FILTROS DE ENEMIGOS (GENERAL vs RAID)
-- ==========================================
local function getAllAliveEnemies()
    local enemyList = {}
    if enemiesFolder then
        for _, object in ipairs(enemiesFolder:GetChildren()) do
            if object:IsA("Model") and object ~= character then
                local humanoid = object:FindFirstChildOfClass("Humanoid")
                local head = object:FindFirstChild("Head")
                if humanoid and humanoid.Health > 0 and head then
                    table.insert(enemyList, object)
                end
            end
        end
    end
    return enemyList
end

local function getMyRaidEnemiesList()
    local enemyList = {}
    if enemiesFolder and humanoidRootPart then
        for _, object in ipairs(enemiesFolder:GetChildren()) do
            if object:IsA("Model") and object ~= character then
                local humanoid = object:FindFirstChildOfClass("Humanoid")
                local head = object:FindFirstChild("Head")
                local root = object:FindFirstChild("HumanoidRootPart")
                
                if humanoid and humanoid.Health > 0 and head and root then
                    local distance = (humanoidRootPart.Position - root.Position).Magnitude
                    if distance <= maxRaidDistance then
                        table.insert(enemyList, object)
                    end
                end
            end
        end
    end
    return enemyList
end

-- ==========================================
-- LOCALIZADOR AJUSTADO DE RAIDS ISLANDS
-- ==========================================
local function findNextRaidIsland(islandNumber)
    local targetName = "island" .. tostring(islandNumber)
    
    for _, object in ipairs(Workspace:GetDescendants()) do
        if object:IsA("BasePart") or object:IsA("Model") or object:IsA("Folder") then
            local cleanName = string.gsub(string.lower(object.Name), "%s+", "")
            
            if string.find(cleanName, targetName) then
                if object:IsA("Model") then
                    if object.PrimaryPart then return object.PrimaryPart end
                    local part = object:FindFirstChildOfClass("BasePart")
                    if part then return part end
                elseif object:IsA("Folder") then
                    local part = object:FindFirstChildOfClass("BasePart") or object:FindFirstChildOfClass("Model")
                    if part then
                        if part:IsA("Model") then return part.PrimaryPart or part:FindFirstChildOfClass("BasePart") end
                        return part
                    end
                elseif object:IsA("BasePart") then
                    return object
                end
            end
        end
    end
    return nil
end

-- ==========================================
-- BUCLE 1: MÓDULO DUNGEON (MATAR A TODOS)
-- ==========================================
local function runDungeonLoop()
    while autoDungeonActive do
        if not character or not character:FindFirstChild("HumanoidRootPart") then
            character = localPlayer.Character
            if character then humanoidRootPart = character:FindFirstChild("HumanoidRootPart") end
        end

        local enemies = getAllAliveEnemies()
        
        if #enemies > 0 then
            for _, enemy in ipairs(enemies) do
                if not autoDungeonActive then break end
                
                local enemyHumanoid = enemy:FindFirstChildOfClass("Humanoid")
                local enemyHead = enemy:FindFirstChild("Head")
                
                if enemyHumanoid and enemyHumanoid.Health > 0 and enemyHead then
                    local maxTime = 0.4    
                    local elapsedTime = 0
                    
                    while elapsedTime < maxTime and enemyHumanoid.Health > 0 and autoDungeonActive do
                        if humanoidRootPart and character:FindFirstChild("Humanoid") and character.Humanoid.Health > 0 then
                            humanoidRootPart.CFrame = enemyHead.CFrame * CFrame.new(0, 20, 0)
                        end
                        
                        executeRealFastAttack(enemy, enemyHead)
                        
                        task.wait(0.01) 
                        elapsedTime = elapsedTime + 0.01
                    end
                end
            end
        end
        task.wait()
    end
end

-- ==========================================
-- BUCLE 2: MÓDULO RAIDS (ESCANEANDO "Isla # despejada!")
-- ==========================================
local function runRaidLoop()
    while autoRaidActive do
        if not character or not character:FindFirstChild("HumanoidRootPart") then
            character = localPlayer.Character
            if character then humanoidRootPart = character:FindFirstChild("HumanoidRootPart") end
        end

        local enemies = getMyRaidEnemiesList()
        
        if #enemies > 0 then
            travelingToNextIsland = false -- Resetear estado si volvieron a aparecer enemigos
            
            for _, enemy in ipairs(enemies) do
                if not autoRaidActive then break end
                
                local enemyHumanoid = enemy:FindFirstChildOfClass("Humanoid")
                local enemyHead = enemy:FindFirstChild("Head")
                
                if enemyHumanoid and enemyHumanoid.Health > 0 and enemyHead then
                    local maxTime = 0.4    
                    local elapsedTime = 0
                    
                    while elapsedTime < maxTime and enemyHumanoid.Health > 0 and autoRaidActive do
                        if humanoidRootPart and character:FindFirstChild("Humanoid") and character.Humanoid.Health > 0 then
                            humanoidRootPart.CFrame = enemyHead.CFrame * CFrame.new(0, 20, 0)
                        end
                        
                        executeRealFastAttack(enemy, enemyHead)
                        
                        task.wait(0.01) 
                        elapsedTime = elapsedTime + 0.01
                    end
                end
            end
        else
            -- CONDICIÓN 1: No hay NPCs vivos en tu rango local.
            -- CONDICIÓN 2: Escanear el aviso de la captura: "Isla #... despejada!"
            if not travelingToNextIsland then
                local playerGui = localPlayer:FindFirstChild("PlayerGui")
                local mainGui = playerGui and playerGui:FindFirstChild("Main")
                local centerMsg = mainGui and mainGui:FindFirstChild("CenterMsg")
                
                if centerMsg and centerMsg.Visible and string.find(string.lower(centerMsg.Text), "despejada") then
                    -- Extraer de forma inteligente el número que está al lado de la palabra isla (ej: "Isla #3 despejada!" -> 3)
                    local text = centerMsg.Text
                    local islandNumStr = string.match(text, "%d+") -- Captura cualquier dígito continuo en el mensaje
                    
                    if islandNumStr then
                        local clearedIsland = tonumber(islandNumStr)
                        currentIslandNumber = clearedIsland + 1 -- Tu objetivo real es la siguiente
                        
                        travelingToNextIsland = true
                        local nextIsland = findNextRaidIsland(currentIslandNumber)
                        
                        if nextIsland and humanoidRootPart then
                            task.wait(0.5)
                            -- Hacer TP seguro 30 unidades arriba de la siguiente isla desbloqueada
                            humanoidRootPart.CFrame = nextIsland.CFrame * CFrame.new(0, 30, 0)
                            task.wait(3.0) -- Pausa de estabilidad para que carguen los nuevos NPCs
                        end
                    end
                end
            end
        end
        task.wait()
    end
end

-- ==========================================
-- AUTO V4 GLOBAL VIA INVENTARIO
-- ==========================================
task.spawn(function()
    while task.wait(1.0) do
        if autoV4Active and character then
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            local playerGui = localPlayer:FindFirstChild("PlayerGui")
            local mainGui = playerGui and playerGui:FindFirstChild("Main")
            local awakeningBar = mainGui and mainGui:FindFirstChild("Awakening")
            
            if awakeningBar and awakeningBar.Visible and humanoid then
                local v4Tool = localPlayer.Backpack:FindFirstChild("Despertar") or character:FindFirstChild("Despertar")
                
                if v4Tool then
                    local currentWeapon = character:FindFirstChildOfClass("Tool")
                    
                    humanoid:EquipTool(v4Tool)
                    task.wait(0.1)
                    v4Tool:Activate()
                    task.wait(0.2)
                    
                    if currentWeapon and currentWeapon.Name ~= "Despertar" then
                        humanoid:EquipTool(currentWeapon)
                    end
                    task.wait(10)
                end
            end
        end
    end
end)

