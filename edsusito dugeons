-- [VARIABLES REALES DE BLOX FRUITS - NETWORKING]
local netFolder = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Net")
local registerAttack = netFolder:WaitForChild("RE/RegisterAttack")
local registerHit = netFolder:WaitForChild("RE/RegisterHit")

local enemiesFolder = Workspace:FindFirstChild("Enemies") or Workspace
local autoCompleteActive = false
local statusLabel

-- ==========================================
-- COMPATIBLE FAST ATTACK ENGINE
-- ==========================================
local function executeRealFastAttack(enemy, headObject)
    if not enemy or not headObject then return end
    
    local tool = character:FindFirstChildOfClass("Tool")
    if tool then
        tool:Activate()
    end
    
    pcall(function()
        local targetsTable = {{enemy, headObject}}
        registerAttack:FireServer(0)
        task.wait(0.01) 
        registerHit:FireServer(headObject, targetsTable)
    end)
end

local function getAliveEnemiesList()
    local enemyList = {}
    if enemiesFolder then
        for _, object in ipairs(enemiesFolder:GetChildren()) do
            if object:IsA("Model") and object ~= character then
                local humanoid = object:FindFirstChildOfClass("Humanoid")
                local head = object:FindFirstChild("Head")
                if humanoid and humanoid.Health > 0 and head then
                    table.insert(enemyList, object)
                end
            end
        end
    end
    return enemyList
end

-- ==========================================
-- SMART FLOOR TRACKER (SELECCIÓN POR CERCANÍA)
-- ==========================================
local function findClosestFloor()
    if not humanoidRootPart then return nil end
    
    local closestPart = nil
    local shortestDistance = math.huge -- Infinito inicial
    
    for _, object in ipairs(Workspace:GetDescendants()) do
        if object:IsA("BasePart") then
            -- Buscar cualquier coincidencia con la palabra floor
            if string.find(string.lower(object.Name), "floor") then
                local distance = (object.Position - humanoidRootPart.Position).Magnitude
                -- Seleccionar estrictamente el que esté más cerca de nuestra posición actual
                if distance < shortestDistance then
                    shortestDistance = distance
                    closestPart = object
                end
            end
        end
    end
    return closestPart
end

-- ==========================================
-- MAIN AUTOMATION LOOP
-- ==========================================
local function startAutoComplete()
    autoCompleteActive = true
    
    while autoCompleteActive do
        -- Forzar re-enganche de seguridad en cada ciclo
        if not character or not character:FindFirstChild("HumanoidRootPart") then
            character = localPlayer.Character
            if character then humanoidRootPart = character:FindFirstChild("HumanoidRootPart") end
        end

        local enemies = getAliveEnemiesList()
        
        if #enemies == 0 then
            if statusLabel then statusLabel.Text = "SYSTEM // WAVE CLEARED!" end
            task.wait(1.0) 
            
            enemies = getAliveEnemiesList()
            
            if #enemies == 0 then
                if statusLabel then statusLabel.Text = "SYSTEM // SCANNING CLOSEST FLOOR..." end
                
                -- Buscar el piso correspondiente a tu Stage actual por cercanía
                local currentFloorPart = findClosestFloor()
                if currentFloorPart and humanoidRootPart then
                    if statusLabel then statusLabel.Text = "SYSTEM // TARGETING: " .. string.upper(currentFloorPart.Name) end
                    
                    -- Teletransporte seguro al centro del piso de tu stage actual
                    humanoidRootPart.CFrame = currentFloorPart.CFrame * CFrame.new(0, 3, 0)
                    task.wait(2.0) 
                else
                    task.wait(0.5)
                end
            end
        else
            for _, enemy in ipairs(enemies) do
                if not autoCompleteActive then break end
                
                local enemyHumanoid = enemy:FindFirstChildOfClass("Humanoid")
                local enemyHead = enemy:FindFirstChild("Head")
                
                if enemyHumanoid and enemyHumanoid.Health > 0 and enemyHead then
                    local maxTime = 0.4    
                    local elapsedTime = 0
                    
                    if statusLabel then 
                        statusLabel.Text = "SYSTEM // PURGING: " .. string.upper(enemy.Name) 
                        statusLabel.TextColor3 = Color3.fromRGB(0, 212, 255)
                    end
                    
                    while elapsedTime < maxTime and enemyHumanoid.Health > 0 and autoCompleteActive do
                        if humanoidRootPart and character:FindFirstChild("Humanoid") and character.Humanoid.Health > 0 then
                            -- Mantener altura de seguridad (10 unidades) sobre el enemigo actual
                            humanoidRootPart.CFrame = enemyHead.CFrame * CFrame.new(0, 10, 0)
                        end
                        
                        executeRealFastAttack(enemy, enemyHead)
                        
                        task.wait(0.01) 
                        elapsedTime = elapsedTime + 0.01
                    end
                end
            end
        end
        task.wait()
    end
end

