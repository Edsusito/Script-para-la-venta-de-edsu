local SAVE_FILE = "zbounty_save.json"
local function saveData()
    pcall(function()
        writefile(SAVE_FILE, HttpService:JSONEncode({
            sessionEarned = State.sessionEarned,
            startBounty   = State.startBounty,
            kills         = State.kills,
