task.spawn(function()
    while true do
        task.wait(0.5)
        pcall(function()
            if not guiReady then return end
            State.currentBounty = getBounty()
            StartLbl.Text  = prefix .. fmt(State.startBounty)
            EarnedLbl.Text = "+" .. prefix .. fmt(State.sessionEarned)
            CurrLbl.Text   = prefix .. fmt(State.currentBounty)
            KillLbl.Text   = "💀  Kills: " .. State.kills

            if State.active then
                local sinceHit  = os.clock() - State.lastHitTime
                local remaining = math.max(0, CONFIG["NoHitTimeout"] - sinceHit)
                local pct       = remaining / CONFIG["NoHitTimeout"]

                TimerBar.Size      = UDim2.new(pct, 0, 1, 0)
                tgrad.Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, pct > 0.4 and C.accentOn or C.red),
                    ColorSequenceKeypoint.new(1, pct > 0.4 and C.accent   or C.gold),
                })

                if remaining > 0 then
                    TimerLbl.Text      = "⏱ " .. math.ceil(remaining) .. "s"
                    TimerLbl.TextColor3 = pct > 0.4 and C.sub or C.gold
                else
                    TimerLbl.Text = "⏱ Hopeando..."
                    TimerLbl.TextColor3 = C.red
                end

                StatusLbl.Text = "⚡ " .. State.status
                StatusLbl.TextColor3 = State.status == "Activo" and C.accentOn or C.gold
            else
                StatusLbl.Text = "⊘ " .. State.status
                StatusLbl.TextColor3 = C.red
                TimerBar.Size = UDim2.new(0, 0, 1, 0)
                TimerLbl.Text = ""
            end
        end)
    end
end)

