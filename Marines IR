task.spawn(function()
    print("[Edsusito] Iniciando — Team=" .. CONFIG["Team"] .. " Weapon=" .. CONFIG["Weapon"])

    local confirmed = false
    local elapsed   = 0

    if player.Team and player.Team.Name == CONFIG["Team"] then
        print("[Edsusito] Ya somos " .. CONFIG["Team"])
        confirmed = true
    elseif player.Team then
        print("[Edsusito] Team actual: " .. player.Team.Name .. " (necesito " .. CONFIG["Team"] .. ")")
    else
        print("[Edsusito] Sin team — buscando pantalla...")
    end

    while not confirmed do
        task.wait(0.3); elapsed += 0.3

        selectFaction(CONFIG["Team"])
        task.wait(0.5)

        if player.Team and player.Team.Name == CONFIG["Team"] then
            print("[Edsusito] Faccion confirmada: " .. CONFIG["Team"])
            confirmed = true
            break
        end

        local ct = findChooseTeam()
        if ct and ct.Visible then
            print("[Edsusito] Pantalla visible → intentando seleccionar " .. CONFIG["Team"])
        end

        if elapsed >= 30 then
            print("[Edsusito] Timeout 30s — arrancando sin confirmar faccion")
            confirmed = true
        end
    end

    if player.Team and player.Team.Name == CONFIG["Team"] then
        StatBadge.Text = "● ACTIVO"
        StatBadge.BackgroundColor3 = C.accentOn
    else
        StatBadge.Text = "● SIN TEAM"
        StatBadge.BackgroundColor3 = C.gold
    end

    task.wait(2)
    if not hasValidTargets() then
        print("[Edsusito] Sin targets Lv." .. CONFIG["MinLevel"] .. "+ → Hopeando")
        State.status = "Sin targets → Hopeando"
        task.wait(2)
        Hop(); task.wait(5)
        State.lastHitTime = os.clock()
        State.status = "Activo"
    end
end)

task.spawn(function()
    local lastVis = false
    while true do
        task.wait(0.5)
        if not State.active then continue end
        local ct = findChooseTeam()
        local vis = ct and ct.Visible or false
        if vis and not lastVis then
            print("[Edsusito] Nuevo server → seleccionando " .. CONFIG["Team"])
            task.wait(0.4)
            for i = 1, 5 do
                selectFaction(CONFIG["Team"])
                task.wait(1.2)
                if player.Team and player.Team.Name == CONFIG["Team"] then break end
            end
        end
        lastVis = vis
    end
end)

