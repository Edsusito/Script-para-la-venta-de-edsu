-- ────────────────────────────────────────────────────────────────
--  RANGO INFINITO PUBLICO EDSUSITO | FINAL MOBILE EDITION
--  Barras de Vida + Botón Flotante + Nitidez HD
-- ────────────────────────────────────────────────────────────────

local function __run()

-- [ CONFIG ]
local CONFIG = {
    ["Team"] = "Marines",
    ["Weapon"] = "Sword",
}

-- [ SERVICIOS ]
local Players          = game:GetService("Players")
local ReplicatedStorage   = game:GetService("ReplicatedStorage")
local RunService          = game:GetService("RunService")
local TweenService        = game:GetService("TweenService")
local VIM                 = game:GetService("VirtualInputManager")
local player              = Players.LocalPlayer
local CommF_             = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("CommF_")

local State = {
    active = false,
    espectando = nil
}

-- [ LÓGICA DE COMBATE ORIGINAL ]
local function down(key)
    pcall(function()
        local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        VIM:SendKeyEvent(true, key, false, hrp)
        task.wait(0.1)
        VIM:SendKeyEvent(false, key, false, hrp)
    end)
end

local function equip(tooltip)
    pcall(function()
        local char = player.Character or player.CharacterAdded:Wait()
        local hum  = char:FindFirstChildOfClass("Humanoid")
        for _, tool in pairs(player.Backpack:GetChildren()) do
            if tool:IsA("Tool") and tool.ToolTip == tooltip then
                hum:EquipTool(tool)
            end
        end
    end)
end

task.spawn(function()
    local angle = 0
    while task.wait() do
        if not State.active then continue end
        pcall(function()
            local char = player.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if root then
                angle = angle + math.rad(25)
                root.CFrame = root.CFrame * CFrame.new(math.cos(angle)*3, 0, math.sin(angle)*3)
                pcall(function() CommF_:InvokeServer("Buso") end)
                equip(CONFIG["Weapon"])
                task.wait(0.1)
                down("Z")
                task.wait(0.4)
                if char:FindFirstChild("Humanoid") then char.Humanoid.Health = 0 end
            end
        end)
        player.CharacterAdded:Wait()
        task.wait(0.5)
    end
end)

RunService.RenderStepped:Connect(function(dt)
    if not State.active then return end
    pcall(function()
        player.Character.HumanoidRootPart.CFrame += Vector3.new(0, 1e5 * dt, 0)
    end)
end)

-- [ GUI - COLORES Y DISEÑO ]
local Theme = {
    Bg = Color3.fromRGB(15, 15, 18),
    Header = Color3.fromRGB(22, 22, 28),
    Accent = Color3.fromRGB(0, 150, 255),
    Green = Color3.fromRGB(0, 255, 120),
    Yellow = Color3.fromRGB(255, 200, 0),
    Red = Color3.fromRGB(255, 50, 70),
    Card = Color3.fromRGB(25, 25, 32)
}

local Screen = Instance.new("ScreenGui", game:GetService("CoreGui"))
Screen.Name = "EdsusitoFinalGUI"
Screen.ResetOnSpawn = false

-- BOTÓN FLOTANTE
local OpenBtn = Instance.new("TextButton", Screen)
OpenBtn.Size = UDim2.new(0, 50, 0, 50)
OpenBtn.Position = UDim2.new(0, 10, 0, 150)
OpenBtn.BackgroundColor3 = Theme.Accent
OpenBtn.Text = "🎯"
OpenBtn.TextSize = 25
OpenBtn.TextColor3 = Color3.new(1, 1, 1)
OpenBtn.Draggable = true -- Para que no estorbe en móvil
Instance.new("UICorner", OpenBtn).CornerRadius = UDim.new(1, 0)
local oStroke = Instance.new("UIStroke", OpenBtn)
oStroke.Thickness = 2; oStroke.Color = Color3.new(1,1,1)

-- PANEL PRINCIPAL
local Main = Instance.new("Frame", Screen)
Main.Size = UDim2.new(0, 300, 0, 480)
Main.Position = UDim2.new(0.5, -150, 0.5, -240)
Main.BackgroundColor3 = Theme.Bg
Main.BorderSizePixel = 0
Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 12)
Instance.new("UIStroke", Main).Color = Theme.Accent

OpenBtn.MouseButton1Click:Connect(function()
    Main.Visible = not Main.Visible
end)

-- HEADER
local Header = Instance.new("Frame", Main)
Header.Size = UDim2.new(1, 0, 0, 50); Header.BackgroundColor3 = Theme.Header; Header.BorderSizePixel = 0
Instance.new("UICorner", Header).CornerRadius = UDim.new(0, 12)
local Title = Instance.new("TextLabel", Header)
Title.Text = "RANGO INFINITO PUBLICO EDSUSITO"; Title.Size = UDim2.new(1,0,1,0); Title.TextColor3 = Color3.new(1,1,1); Title.Font = Enum.Font.GothamBlack; Title.TextSize = 12; Title.BackgroundTransparency = 1
Instance.new("UIStroke", Title).Thickness = 1

-- BOTÓN MAESTRO (HD)
local PowerBtn = Instance.new("TextButton", Main)
PowerBtn.Size = UDim2.new(0.9, 0, 0, 90)
PowerBtn.Position = UDim2.new(0.05, 0, 0, 65)
PowerBtn.BackgroundColor3 = Theme.Red
PowerBtn.Text = "SISTEMA\nDESACTIVADO"
PowerBtn.TextColor3 = Color3.new(1,1,1); PowerBtn.Font = Enum.Font.GothamBlack; PowerBtn.TextSize = 22; PowerBtn.RichText = true
Instance.new("UICorner", PowerBtn).CornerRadius = UDim.new(0, 10)
local pStroke = Instance.new("UIStroke", PowerBtn); pStroke.Thickness = 2; pStroke.Color = Color3.new(0,0,0)

-- LISTA DE JUGADORES
local Scroll = Instance.new("ScrollingFrame", Main)
Scroll.Size = UDim2.new(0.9, 0, 0, 290)
Scroll.Position = UDim2.new(0.05, 0, 0, 170)
Scroll.BackgroundTransparency = 1; Scroll.ScrollBarThickness = 2
local Layout = Instance.new("UIListLayout", Scroll); Layout.Padding = UDim.new(0, 8)

local function CreateCard(plr)
    if plr == player then return end
    local Card = Instance.new("Frame")
    Card.Size = UDim2.new(1, -5, 0, 65); Card.BackgroundColor3 = Theme.Card; Instance.new("UICorner", Card).CornerRadius = UDim.new(0, 8)
    
    local Avatar = Instance.new("ImageLabel", Card)
    Avatar.Size = UDim2.new(0, 40, 0, 40); Avatar.Position = UDim2.new(0, 8, 0, 8)
    Avatar.Image = Players:GetUserThumbnailAsync(plr.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size100x100)
    Instance.new("UICorner", Avatar).CornerRadius = UDim.new(1, 0)

    local Name = Instance.new("TextLabel", Card)
    Name.Text = plr.DisplayName; Name.Size = UDim2.new(0, 110, 0, 20); Name.Position = UDim2.new(0, 55, 0, 8); Name.TextColor3 = Color3.new(1,1,1); Name.Font = Enum.Font.GothamBold; Name.TextSize = 11; Name.TextXAlignment = Enum.TextXAlignment.Left; Name.BackgroundTransparency = 1

    local Spec = Instance.new("TextButton", Card)
    Spec.Text = "VIEW"; Spec.Size = UDim2.new(0, 55, 0, 22); Spec.Position = UDim2.new(1, -65, 0, 8); Spec.BackgroundColor3 = Theme.Accent; Spec.TextColor3 = Color3.new(1,1,1); Spec.Font = Enum.Font.GothamBold; Spec.TextSize = 8; Instance.new("UICorner", Spec).CornerRadius = UDim.new(0, 5)

    -- BARRA DE VIDA
    local BarBg = Instance.new("Frame", Card)
    BarBg.Size = UDim2.new(1, -65, 0, 5); BarBg.Position = UDim2.new(0, 55, 1, -15); BarBg.BackgroundColor3 = Color3.fromRGB(40, 40, 45); Instance.new("UICorner", BarBg).CornerRadius = UDim.new(1, 0)
    local Bar = Instance.new("Frame", BarBg)
    Bar.Size = UDim2.new(1, 0, 1, 0); Bar.BackgroundColor3 = Theme.Green; Instance.new("UICorner", Bar).CornerRadius = UDim.new(1, 0)

    Spec.MouseButton1Click:Connect(function()
        if State.espectando == plr then 
            State.espectando = nil; workspace.CurrentCamera.CameraSubject = player.Character.Humanoid; Spec.Text = "VIEW"; Spec.BackgroundColor3 = Theme.Accent
        else 
            State.espectando = plr; workspace.CurrentCamera.CameraSubject = plr.Character.Humanoid; Spec.Text = "LIVE"; Spec.BackgroundColor3 = Theme.Red 
        end
    end)

    task.spawn(function()
        while Card.Parent do
            pcall(function()
                local h = plr.Character.Humanoid
                local pct = math.clamp(h.Health / h.MaxHealth, 0, 1)
                Bar.Size = UDim2.new(pct, 0, 1, 0)
                Bar.BackgroundColor3 = pct > 0.6 and Theme.Green or pct > 0.3 and Theme.Yellow or Theme.Red
            end)
            task.wait(0.5)
        end
    end)
    return Card
end

local function Refresh()
    for _, v in pairs(Scroll:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
    for _, p in pairs(Players:GetPlayers()) do
        local c = CreateCard(p); if c then c.Parent = Scroll end
    end
    Scroll.CanvasSize = UDim2.new(0, 0, 0, Layout.AbsoluteContentSize.Y + 10)
end

Players.PlayerAdded:Connect(Refresh); Players.PlayerRemoving:Connect(Refresh); Refresh()

PowerBtn.MouseButton1Click:Connect(function()
    State.active = not State.active
    PowerBtn.BackgroundColor3 = State.active and Theme.Green or Theme.Red
    PowerBtn.Text = State.active and "SISTEMA\nENCENDIDO" or "SISTEMA\nDESACTIVADO"
end)

-- ARRASTRE PANEL
local d1, d2, d3
Header.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then d1 = true; d2 = i.Position; d3 = Main.Position end end)
game:GetService("UserInputService").InputChanged:Connect(function(i) if d1 and i.UserInputType == Enum.UserInputType.MouseMovement then local delta = i.Position - d2; Main.Position = UDim2.new(d3.X.Scale, d3.X.Offset + delta.X, d3.Y.Scale, d3.Y.Offset + delta.Y) end end)
game:GetService("UserInputService").InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then d1 = false end end)

print("Edsusito Rango Final Cargado - ¡Listo para móvil!")

end
__run()
