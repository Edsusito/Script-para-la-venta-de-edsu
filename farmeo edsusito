-- AUTO SEA DUNGEON (SEA BEAST)
-- ========================
local AutoSeaThread
local function startAutoSeaDungeon()
    if AutoSeaThread then task.cancel(AutoSeaThread) end
    AutoSeaThread = task.spawn(function()
        while AUTO_SEA_DUNGEON do
            task.wait(0.3)
            local char, myHRP = getCharacter()
            if not char then task.wait(1) continue end
            
            -- Buscar Sea Beast
            local seaBeast = nil
            for _, npc in pairs(workspace:GetDescendants()) do
                if npc.Name == "SeaBeast1" or npc.Name == "Sea Beast" then
                    local hum = npc:FindFirstChildOfClass("Humanoid")
                    if hum and hum.Health > 0 then
                        seaBeast = npc
                        break
                    end
                end
            end
            
            if seaBeast then
                local part = seaBeast:FindFirstChild("HumanoidRootPart") or seaBeast:FindFirstChildWhichIsA("BasePart")
                if part then
                    myHRP.CFrame = part.CFrame * CFrame.new(0, 30, 0)
                    fastAttack()
                end
            end
        end
    end)
end

