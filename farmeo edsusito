-- ========================
-- UTILS
-- ========================
local function getLevel()
    local data = LP:FindFirstChild("Data")
    if data and data:FindFirstChild("Level") then
        return data.Level.Value
    end
    return 0
end

local function getMastery()
    local char = LP.Character
    if not char then return 0 end
    local tool = char:FindFirstChildOfClass("Tool")
    if tool then
        local lvl = tool:FindFirstChild("Level")
        if lvl then return lvl.Value end
    end
    return 0
end

local function getCharacter()
    local char = LP.Character
    if not char then return nil end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChild("Humanoid")
    if hrp and hum and hum.Health > 0 then return char, hrp, hum end
    return nil
end

local function Press(key)
    VirtualInputManager:SendKeyEvent(true, key, false, game)
    task.wait(0.05)
    VirtualInputManager:SendKeyEvent(false, key, false, game)
end

local function getIslaParaNivel(lvl)
    for _, isla in ipairs(ISLAS) do
        if lvl >= isla[1] and lvl <= isla[2] then
            return isla
        end
    end
    return ISLAS[#ISLAS]
end

-- ========================
-- BUDDHA
-- ========================
local function isBuddhaActive()
    local char = LP.Character
    if not char then return false end
    local hum = char:FindFirstChild("Humanoid")
    if hum and hum.HipHeight > 5 then return true end
    return false
end

local function equipBuddha()
    local backpack = LP:FindFirstChild("Backpack")
    local char = LP.Character
    if not char or not backpack then return false end
    
    -- Si ya está equipada
    local equipped = char:FindFirstChild("Buddha-Buddha") or char:FindFirstChild("Buddha")
    if equipped then return true end
    
    -- Buscar en la mochila
    for _, tool in pairs(backpack:GetChildren()) do
        if tool:IsA("Tool") and tool.Name:lower():find("buddha") then
            local hum = char:FindFirstChild("Humanoid")
            if hum then hum:EquipTool(tool) end
            return true
        end
    end
    return false
end

local function activateBuddha()
    if isBuddhaActive() then return end
    if equipBuddha() then
        task.wait(0.3)
        Press(Enum.KeyCode.Z)
        task.wait(0.5)
    end
end

-- ========================
-- MOBS
-- ========================
local function getMob(nombre)
    local enemies = workspace:FindFirstChild("Enemies")
    if not enemies then return nil end
    
    local closest = nil
    local minDist = math.huge
    local _, myHRP = getCharacter()
    if not myHRP then return nil end
    
    for _, mob in pairs(enemies:GetChildren()) do
        if mob.Name == nombre then
            local hum = mob:FindFirstChild("Humanoid")
            local hrp = mob:FindFirstChild("HumanoidRootPart")
            if hum and hrp and hum.Health > 0 then
                local dist = (hrp.Position - myHRP.Position).Magnitude
                if dist < minDist then
                    minDist = dist
                    closest = mob
                end
            end
        end
    end
    return closest
end

local function getMobsCerca(rango)
    local enemies = workspace:FindFirstChild("Enemies")
    if not enemies then return {} end
    
    local _, myHRP = getCharacter()
    if not myHRP then return {} end
    
    local mobs = {}
    for _, mob in pairs(enemies:GetChildren()) do
        local hum = mob:FindFirstChild("Humanoid")
        local hrp = mob:FindFirstChild("HumanoidRootPart")
        local head = mob:FindFirstChild("Head")
        if hum and hrp and head and hum.Health > 0 then
            local dist = (hrp.Position - myHRP.Position).Magnitude
            if dist <= rango then
                table.insert(mobs, {mob, head})
            end
        end
    end
    return mobs
end

-- ========================
-- FAST ATTACK CON HITBOX
-- ========================
local function fastAttack()
    local mobs = getMobsCerca(FAST_ATTACK_RANGE)
    if #mobs == 0 then return end
    
    pcall(function()
        RegisterAttack:FireServer(0)
        task.wait(0.02)
        RegisterHit:FireServer(mobs[1][2], mobs)
    end)
end

local function tpAlMob(mob)
    local _, myHRP = getCharacter()
    if not myHRP or not mob then return end
    local mobHRP = mob:FindFirstChild("HumanoidRootPart")
    if not mobHRP then return end
    myHRP.CFrame = mobHRP.CFrame * CFrame.new(0, FARM_HEIGHT, 0)
end

local function aceptarMision(questGiver, questNum)
    pcall(function()
        CommF:InvokeServer("StartQuest", questGiver, questNum)
    end)
end

-- ========================
-- AUTO FARM LEVEL
-- ========================
local AutoFarmThread
local function startAutoFarmLvl()
    if AutoFarmThread then task.cancel(AutoFarmThread) end
    AutoFarmThread = task.spawn(function()
        while AUTO_FARM_LVL do
            task.wait(0.1)
            local char, myHRP, hum = getCharacter()
            if not char then task.wait(1) continue end
            
            local lvl = getLevel()
            local isla = getIslaParaNivel(lvl)
            if not isla then continue end
            
            local _, _, questGiver, questNum, mobName, spawnCF = unpack(isla)
            
            if AUTO_BUDDHA and not isBuddhaActive() then
                activateBuddha()
                task.wait(0.3)
            end
            
            local mob = getMob(mobName)
            if not mob then
                myHRP.CFrame = spawnCF
                task.wait(0.5)
                aceptarMision(questGiver, questNum)
                task.wait(0.5)
            else
                tpAlMob(mob)
                task.wait(0.1)
                fastAttack()
            end
        end
    end)
end

-- ========================
-- AUTO BOSS FARM
-- ========================
local AutoBossThread
local function startAutoBoss()
    if AutoBossThread then task.cancel(AutoBossThread) end
    AutoBossThread = task.spawn(function()
        while AUTO_BOSS do
            task.wait(0.1)
            local char, myHRP = getCharacter()
            if not char then task.wait(1) continue end
            
            if AUTO_BUDDHA and not isBuddhaActive() then
                activateBuddha()
            end
            
            -- Buscar boss vivo más cercano
            local enemies = workspace:FindFirstChild("Enemies")
            if not enemies then continue end
            
            local foundBoss = nil
            for _, bossData in ipairs(BOSSES) do
                local bossName = bossData[1]
                for _, mob in pairs(enemies:GetChildren()) do
                    if mob.Name == bossName then
                        local hum = mob:FindFirstChild("Humanoid")
                        if hum and hum.Health > 0 then
                            foundBoss = mob
                            break
                        end
                    end
                end
                if foundBoss then break end
            end
            
            if foundBoss then
                tpAlMob(foundBoss)
                fastAttack()
            else
                -- Ir al primer boss disponible para spawnearlo
                myHRP.CFrame = BOSSES[1][2]
                task.wait(1)
            end
        end
    end)
end

-- ========================
-- AUTO RAID (CHIPS / FRUIT RAID)
-- ========================
local AutoRaidThread
local function startAutoRaid()
    if AutoRaidThread then task.cancel(AutoRaidThread) end
    AutoRaidThread = task.spawn(function()
        while AUTO_RAID do
            task.wait(0.5)
            local char, myHRP = getCharacter()
            if not char then task.wait(1) continue end
            
            if AUTO_BUDDHA and not isBuddhaActive() then
                activateBuddha()
            end
            
            -- Detectar si estamos en un raid
            local inRaid = false
            pcall(function()
                if workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("Island") then
                    inRaid = true
                end
            end)
            
            if not inRaid then
                -- Activar chip de raid
                pcall(function()
                    CommF:InvokeServer("StartChipInteraction")
                end)
                task.wait(2)
            else
                -- Matar mobs del raid
                local mobs = getMobsCerca(FAST_ATTACK_RANGE)
                if #mobs > 0 then
                    tpAlMob(mobs[1][1])
                    fastAttack()
                end
            end
        end
    end)
end

