local PlayerGui = localPlayer:WaitForChild("PlayerGui")

-- ⚙️ VARIABLES GLOBALES
local character = localPlayer.Character or localPlayer.CharacterAdded:Wait()
local humanoidRootPart = character:WaitForChild("HumanoidRootPart")

local autoDungeonActive = false
local v4Enabled = false
local autoBlessingActive = false
local justDied = false
local characterLoaded = true
local attackHeight = 40 
local selectedWeaponType = "Sword"
local currentTarget = nil
local lastTarget = nil

local PriorityList = {"Sword Damage", "Fortress", "Life Steal", "Race Meter", "Defense", "Health", "Energy"}

local netFolder = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Net")
local registerAttack = netFolder:WaitForChild("RE/RegisterAttack")
local registerHit = netFolder:WaitForChild("RE/RegisterHit")
local enemiesFolder = Workspace:FindFirstChild("Enemies") or Workspace
local commF = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("CommF_")

-- 🔄 CONTROL DE REAPARICIÓN
localPlayer.CharacterAdded:Connect(function(newCharacter)
    characterLoaded = false
    justDied = true
    
    local humanoid = newCharacter:WaitForChild("Humanoid")
    local rootPart = newCharacter:WaitForChild("HumanoidRootPart")
    
    while not (newCharacter.Parent == Workspace and humanoid and rootPart and humanoid.Health > 0 and rootPart.Position.Magnitude > 10) do
        task.wait(0.1)
    end
    
    task.wait(0.5)
    character = newCharacter
    humanoidRootPart = rootPart
    characterLoaded = true
end)

-- 🛡️ FUNCIONES DE COMBATE (HAKI Y ARMAS)
local function IsHakiActive()
    return character and character:FindFirstChild("HasBuso") ~= nil
end

local function ForceActivateHaki()
    if autoDungeonActive and characterLoaded and not IsHakiActive() then
        pcall(function() commF:InvokeServer("Buso") end)
    end
end

local function ForceEquipWeapon()
    if not autoDungeonActive or not characterLoaded then return end
    
    local currentTool = character:FindFirstChildOfClass("Tool")
    if currentTool and currentTool.ToolTip == selectedWeaponType then return end
    
    local backpack = localPlayer:FindFirstChildOfClass("Backpack")
    if backpack then
        for _, tool in ipairs(backpack:GetChildren()) do
            if tool:IsA("Tool") and tool.ToolTip == selectedWeaponType then
                local humanoid = character:FindFirstChildOfClass("Humanoid")
                if humanoid then 
                    humanoid:EquipTool(tool) 
                    break 
                end
            end
        end
    end
end

-- 🎯 BÚSQUEDA Y ATAQUE DE ENEMIGOS
local function GetClosestEnemy()
    if justDied or not characterLoaded then return nil end 
    local closestEnemy = nil
    local shortestDistance = math.huge
    local currentCharacter = localPlayer.Character
    
    if not currentCharacter or not currentCharacter:FindFirstChild("HumanoidRootPart") then return nil end
    local myPos = currentCharacter.HumanoidRootPart.Position
    local sourceFolder = Workspace:FindFirstChild("Enemies") or enemiesFolder
    
    if sourceFolder then
        local children = sourceFolder:GetChildren()
        for i = 1, #children do
            local object = children[i]
            if object:IsA("Model") and object ~= currentCharacter and object.Name ~= "Blank Buddy" and object.Name ~= "Sombra" and object.Name ~= "Shadow" then
                local humanoid = object:FindFirstChildOfClass("Humanoid")
                local root = object:FindFirstChild("HumanoidRootPart") or object:FindFirstChild("Head")
                
                if humanoid and humanoid.Health > 0 and root and object.Parent then
                    local distance = (root.Position - myPos).Magnitude
                    if distance < shortestDistance then
                        shortestDistance = distance
                        closestEnemy = object
                    end
                end
            end
        end
    end
    return closestEnemy
end

local function TeleportToEnemy(enemy)
    if not enemy or not enemy.Parent or not humanoidRootPart or not characterLoaded then return false end
    local enemyRoot = enemy:FindFirstChild("HumanoidRootPart") or enemy:FindFirstChild("Head")
    if not enemyRoot then return false end
    
    local success = pcall(function()
        humanoidRootPart.CFrame = enemyRoot.CFrame * CFrame.new(0, attackHeight, 0)
    end)
    return success
end

local function AttackEnemy(enemy)
    if not enemy or not enemy.Parent or not characterLoaded then return end
    local enemyHead = enemy:FindFirstChild("Head")
    if not enemyHead then return end
    
    local tool = character:FindFirstChildOfClass("Tool")
    if tool then tool:Activate() end
    
    pcall(function()
        registerAttack:FireServer(0)
        registerHit:FireServer(enemyHead, {{enemy, enemyHead}})
    end)
end

local function AutoPassRoom()
    if not characterLoaded or not humanoidRootPart then return false end
    local mapFolder = Workspace:FindFirstChild("Map")
    if not mapFolder then return false end
    local dungeonFolder = mapFolder:FindFirstChild("Dungeon")
    if not dungeonFolder then return false end
    
    local rooms = dungeonFolder:GetChildren()
    if #rooms == 0 then return false end
    
    local myPos = humanoidRootPart.Position
    local currentRoomIdx = 1
    local minDistanceToRoomCenter = math.huge
    
    for i, room in ipairs(rooms) do
        local roomPart = room:FindFirstChildOfClass("Part") or room:FindFirstChildOfClass("MeshPart") or room:FindFirstChild("Floor")
        if roomPart then
            local dist = (roomPart.Position - myPos).Magnitude
            if dist < minDistanceToRoomCenter then
                minDistanceToRoomCenter = dist
                currentRoomIdx = i
            end
        end
    end
    
    local activeRoom = rooms[currentRoomIdx]
    if activeRoom then
        local teleporter = activeRoom:FindFirstChild("ExitTeleporter")
        if teleporter and teleporter:FindFirstChild("Root") then
            local rootPart = teleporter.Root
            humanoidRootPart.CFrame = rootPart.CFrame
            task.wait(0.12)
            if firetouchinterest then
                firetouchinterest(humanoidRootPart, rootPart, 0)
                task.wait(0.1)
                firetouchinterest(humanoidRootPart, rootPart, 1)
            end
            justDied = false
            return true
        end
    end
    return false
end

local function RotateTargets()
    while autoDungeonActive do
        currentTarget = GetClosestEnemy()
        if currentTarget and not justDied and characterLoaded then
            lastTarget = currentTarget
            local enemyHumanoid = currentTarget:FindFirstChildOfClass("Humanoid")
            local timer = 0
            
            while autoDungeonActive and currentTarget and currentTarget.Parent and enemyHumanoid and enemyHumanoid.Health > 0 and timer < 0.5 and not justDied and characterLoaded do
                TeleportToEnemy(currentTarget)
                AttackEnemy(currentTarget)
                task.wait(0.01)
                timer = timer + 0.01
            end
        else
            if justDied and characterLoaded then
                local attempts = 0
                while autoDungeonActive and justDied and attempts < 10 and characterLoaded do
                    if AutoPassRoom() then break end
                    attempts = attempts + 1
                    task.wait(0.5)
                end
                justDied = false
            else
                task.wait(1.0)
                if characterLoaded then AutoPassRoom() end
            end
        end
        task.wait(0.05)
    end
end

