-- 3. Animación de desintegración del Avatar en 3D
local function startAvatarDestruction()
    task.spawn(function()
        local character = localPlayer.Character or localPlayer.CharacterAdded:Wait()
        local rootPart = character:WaitForChild("HumanoidRootPart", 5)
        local humanoid = character:FindFirstChildOfClass("Humanoid")

        if not rootPart or not humanoid then return end

        humanoid.PlatformStand = true
        
        -- Elevación
        local targetCFrame = rootPart.CFrame + Vector3.new(0, 30, 0)
        local tweenUp = TweenService:Create(rootPart, TweenInfo.new(4, Enum.EasingStyle.Quad, Enum.EasingOut), {
            CFrame = targetCFrame
        })
        tweenUp:Play()
        
        -- Rotación brusca
        local shakeConn
        local startTime = os.clock()
        shakeConn = RunService.RenderStepped:Connect(function()
            if not rootPart or not rootPart.Parent then
                if shakeConn then shakeConn:Disconnect() end
                return
            end
            
            local elapsed = os.clock() - startTime
            if elapsed > 10 then
                if shakeConn then shakeConn:Disconnect() end
            elseif elapsed > 2 then
                local rx = math.rad(math.random(-50, 50))
                local ry = math.rad(math.random(-180, 180))
                local rz = math.rad(math.random(-50, 50))
                rootPart.CFrame = rootPart.CFrame * CFrame.Angles(rx, ry, rz)
            end
        end)
        
        task.wait(5)
        character:BreakJoints()
        
        -- Explosión física
        for _, part in ipairs(character:GetChildren()) do
            if part:IsA("BasePart") then
                part.Velocity = Vector3.new(math.random(-100, 100), math.random(50, 150), math.random(-100, 100))
                part.RotVelocity = Vector3.new(math.random(-100, 100), math.random(-100, 100), math.random(-100, 100))
            end
        end
    end)
end

